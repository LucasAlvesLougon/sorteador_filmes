# Configurações da Aplicação
# COPIE ESTE ARQUIVO E RENOMEIE PARA .env
# NÃO COLOQUE SENHAS REAIS AQUI!

# Porta do servidor
PORT=3000

# URL de conexão com MongoDB
# Opções:
# - Local: mongodb://localhost:27017/sorteador_filmes
# - MongoDB Atlas: mongodb+srv://seu_usuario:sua_senha@seu_cluster.mongodb.net/sorteador_filmes?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://seu_usuario:sua_senha@seu_cluster.mongodb.net/sorteador_filmes?retryWrites=true&w=majority

# Environment: development ou production
NODE_ENV=production

# URL do frontend (para CORS seguro em produção)
FRONTEND_URL=https://seu-dominio.com
